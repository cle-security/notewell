{
  "name": "cle-demo-notes",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "installOhMyZshConfig": true
    }
  },
  "remoteUser": "node",
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": { "label": "api (fastify)", "onAutoForward": "notify" },
    "5173": { "label": "web (vite)", "onAutoForward": "openPreview" }
  },
  "mounts": [
    "source=cle-demo-notes-claude,target=/home/node/.claude,type=volume",
    "source=cle-demo-notes-history,target=/commandhistory,type=volume"
  ],
  "containerEnv": {
    "HISTFILE": "/commandhistory/.zsh_history"
  },
  "postCreateCommand": ".devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vitest.explorer",
        "qwtel.sqlite-viewer",
        "anthropic.claude-code",
        "redhat.vscode-yaml",
        "MS-SarifVSCode.sarif-viewer"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[vue]": { "editor.defaultFormatter": "Vue.volar" },
        "eslint.workingDirectories": [
          { "pattern": "apps/*" },
          { "pattern": "packages/*" }
        ]
      }
    }
  }
}
