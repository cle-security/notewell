# NOTEWELL_SITE_ADDRESS is provided by docker-compose:
#   - a domain (e.g. notewell.app) -> automatic HTTPS via Let's Encrypt
#   - ":80" (the default)          -> plain HTTP, for local `docker compose up`
{$NOTEWELL_SITE_ADDRESS} {
    encode zstd gzip

    # Security headers added at the edge (the app does not set these itself).
    # Tighten the CSP once you've confirmed it doesn't break the SPA.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        # Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
        -Server
    }

    # API -> Fastify app container on the internal Docker network.
    handle /api/* {
        reverse_proxy app:3000
    }

    # Single-page app: serve static files, fall back to index.html for client routes.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
