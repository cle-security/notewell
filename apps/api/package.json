{
  "name": "@notewell/api",
  "version": "0.1.0",
  "description": "Notewell API — Fastify + Prisma backend.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx prisma/seed.ts",
    "test": "tsx --test src/smoke.test.ts"
  },
  "dependencies": {
    "@notewell/types": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.19.1",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "prisma": "^5.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
