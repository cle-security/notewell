# Production environment for the Notewell API container.
# Copy to deploy/.env and fill in. docker-compose loads this via `env_file`.

# REQUIRED — signs session cookies (must be >= 32 chars). Generate one with:
#   openssl rand -base64 48
SESSION_SECRET=

# Max attachment size in bytes (default: 5 MiB).
MAX_UPLOAD_BYTES=5242880

# Optional — consumed only by the one-time seed when creating the first admin.
# ADMIN_EMAIL=you@notewell.app
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Deliberately NOT set here:
#   DATABASE_URL, UPLOAD_DIR  -> fixed by docker-compose to the /data volume.
#   NOTEWELL_DOMAIN           -> set in your shell / root .env to turn on HTTPS,
#                                e.g. NOTEWELL_DOMAIN=notewell.app
# ---------------------------------------------------------------------------
